#!/usr/bin/env bash
#### RetroMi — Background music for EmulationStation (mpg123 + bundled MP3)
#### Volume fixed at gain 40 (independent of system ALSA volume) via mpg123 -g flag

# shellcheck enable=require-variable-braces
set -Ee

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Setting up retro background music..."

# Install mpg123 (background music player)
apt-get install -y --no-install-recommends mpg123

# Deploy music files + setup scripts
unpack /filesystem/home/pi /home/pi

# Run setup (deploys autostart.sh, runcommand hooks, RetroPie menu shortcuts)
cd /home/pi/music_setup
chmod +x setup.sh
./setup.sh

# Deploy bundled MP3 tracks (arcade-party-173553.mp3 already in /home/pi/RetroPie/music)
# Additional MP3s can be placed in /home/pi/RetroPie/music/ at any time

# Fix ownership
chown -R pi:pi /home/pi/RetroPie/music
chown -R pi:pi /home/pi/music_settings
chmod 755 /home/pi/RetroPie/music

echo_green "Background music setup complete. Volume: gain 40 (adjustable via mpg123 -g). (DONE)"
