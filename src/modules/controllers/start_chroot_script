#!/usr/bin/env bash
#### RetroMi — Controller udev rules
#### Installs plug & play udev rules for PS3/PS4/PS5, Xbox, Switch, 8BitDo.
#### Users get joystick access without root or config.

# shellcheck enable=require-variable-braces
set -Ee

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Installing controller udev rules..."

# Deploy rules from filesystem/
unpack /filesystem/etc/udev/rules.d /etc/udev/rules.d

# Deploy pre-configured ES input mappings (prevents first-boot wizard)
# Includes: keyboard, PS3/PS4/PS5, Xbox 360/One/Series, Switch Pro, 8BitDo, Logitech
mkdir -p /opt/retropie/configs/all/emulationstation
unpack /filesystem/opt/retropie/configs/all/emulationstation /opt/retropie/configs/all/emulationstation
echo_green "Pre-configured controller mappings installed (es_input.cfg)"

# Ensure 'pi' user has joystick access
usermod -aG input pi

# Load joydev kernel module at boot (required for /dev/input/js* devices)
echo "joydev" > /etc/modules-load.d/retromi-controllers.conf

echo_green "Controller udev rules installed. (DONE)"