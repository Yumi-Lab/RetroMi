#!/usr/bin/env bash
#### RetroMi — RetroArch config deployment
#### Deploys pre-baked retroarch.cfg (H3/Mali-400 optimized) + SDL_GameControllerDB.
#### RetroArch itself is installed by the retropie module via RetroMi-packages.

# shellcheck enable=require-variable-braces
set -Ee

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Deploying RetroArch config (H3/Mali-400 optimized)..."

# Create required directories (remove file if retropie installed it as a file instead of a directory)
rm -f /opt/retropie/configs/all/retroarch-joypads 2>/dev/null || true
mkdir -p /opt/retropie/configs/all/retroarch-joypads
mkdir -p /home/pi/RetroPie/saves
mkdir -p /home/pi/RetroPie/savestates
mkdir -p /home/pi/RetroPie/screenshots

# Deploy retroarch.cfg + joypad configs from filesystem
unpack /filesystem/opt/retropie/configs/all /opt/retropie/configs/all

# SDL_GameControllerDB — plug & play pour 4000+ manettes
# SHA pinned — updated automatically by update-deps.yml workflow
SDLDB_COMMIT="e0beee4ed92cf4360ff960c1feff17ed895b81bc"
echo_green "Downloading SDL_GameControllerDB (${SDLDB_COMMIT:0:7})..."
curl -sSL \
  "https://raw.githubusercontent.com/gabomdq/SDL_GameControllerDB/${SDLDB_COMMIT}/gamecontrollerdb.txt" \
  -o /opt/retropie/configs/all/gamecontrollerdb.txt

# Fix ownership
chown -R pi:pi /home/pi/RetroPie
chown -R pi:pi /opt/retropie/configs/all

echo_green "RetroArch config deployed. (DONE)"