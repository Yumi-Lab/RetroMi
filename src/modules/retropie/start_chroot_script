#!/usr/bin/env bash
#### RetroPie — Install pre-compiled packages from RetroMi-packages
# shellcheck enable=require-variable-braces

set -Ee
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Installing RetroPie (pre-compiled packages)..."

# Runtime dependencies (no compiler needed)
apt-get update
check_install_pkgs ${RETROPIE_DEPS}

# Download and extract each pre-compiled package group
mkdir -p /opt/retropie

for group in ${RETROPIE_PACKAGE_GROUPS}; do
    echo_green "Downloading ${group} packages..."
    wget --tries=3 --waitretry=10 --timeout=60 --show-progress \
        -O "/tmp/packages-${group}-armhf.tar.gz" \
        "${RETROPIE_PACKAGES_URL}/packages-${group}-armhf.tar.gz"

    echo_green "Extracting ${group} packages..."
    tar -xzf "/tmp/packages-${group}-armhf.tar.gz" -C /
    rm -f "/tmp/packages-${group}-armhf.tar.gz"
done

# Create all ROM directories so the structure is ready for USB auto-mount
ROM_DIR="/home/${BASE_USER}/RetroPie/roms"
mkdir -p "${ROM_DIR}"
for sys in \
    nes snes megadrive mastersystem gamegear genesis sega32x segacd sg-1000 \
    gb gbc gba nds n64 \
    psx psp \
    atari2600 atari5200 atari7800 atarilynx atarist \
    pcengine ngp ngpc wonderswan wonderswancolor \
    mame-libretro fba arcade neogeo \
    scummvm dosbox \
    c64 msx zxspectrum amstradcpc amiga \
    dreamcast saturn 3do jaguar \
    vectrex coleco intellivision \
    virtualboy pokemini supervision megaduck uzebox arduboy \
    pc88 pc98 x68000 x1 \
    ports; do
    mkdir -p "${ROM_DIR}/${sys}"
done
chown -R "${BASE_USER}:${BASE_USER}" "${ROM_DIR}"

# Clone YUMI-RETROPIE for post-install configuration only (no compilation)
pushd "/home/${BASE_USER}" &>/dev/null || exit 1
gitclone RETROPIE_REPO Retropie-Setup
popd &>/dev/null || exit 1

# Force platform detection for QEMU builds (prevents -march=native on x86 host)
# Without this, RetroPie-Setup falls back to platform_native() in QEMU chroot,
# which compiles with host CPU instructions → "Illegal instruction" on real H3
export __platform="armv7-mali"

# Run post-install steps: EmulationStation, Bluetooth, USB ROM service, autostart
pushd "/home/${BASE_USER}/Retropie-Setup" &>/dev/null || exit 1
bash retropie_packages.sh emulationstation
bash retropie_packages.sh bluetooth depends
bash retropie_packages.sh usbromservice

# Register all pre-compiled libretro cores in EmulationStation
# Each 'configure' step calls addSystem → populates es_systems.cfg + emulators.cfg
echo_green "Registering installed emulators in EmulationStation..."
for core_dir in /opt/retropie/libretrocores/lr-*/; do
    [ -d "${core_dir}" ] || continue
    core_name=$(basename "${core_dir}")
    echo_green "  → ${core_name}"
    bash retropie_packages.sh "${core_name}" configure 2>/dev/null || true
done
echo_green "Registering installed emulators... [DONE]"

# Configure the RetroPie settings menu (visible as a system in ES)
bash retropie_packages.sh retropiemenu configure 2>/dev/null || true

bash autostartES.sh
popd &>/dev/null || exit 1

# Fix ownership
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/Retropie-Setup"
chown -R "${BASE_USER}:${BASE_USER}" "/opt/retropie/configs" 2>/dev/null || true

echo_green "Installing RetroPie (pre-compiled packages)... [DONE]"
